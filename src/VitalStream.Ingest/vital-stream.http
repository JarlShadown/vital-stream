@host = http://localhost:8081
@deviceId = device-001

# NOTE: The HMAC signatures below are pre-computed for the exact body bytes shown.
# Any change to whitespace or field order will invalidate the signature.
# To regenerate: echo -n '<body>' | openssl dgst -sha256 -hmac 'dev-secret-replace-me'
#
# VitalType enum: HeartRate=0, SpO2=1, BloodPressureSystolic=2, BloodPressureDiastolic=3, Temperature=4

### 1. HeartRate Normal (72 bpm) → Severity: Normal → 200 OK
POST {{host}}/ingest/{{deviceId}}
Content-Type: application/json
X-Signature-256: sha256=b355b1502c4ca17f1e52ca8b98205017bad67f4e62df55b8c7040d0cf92f0e05

{"patientId":"a1b2c3d4-e5f6-7890-abcd-ef1234567890","deviceId":"device-001","deviceType":"Wearable","type":0,"value":72.0,"unit":"bpm","recordedAt":"2026-03-31T10:00:00+00:00","receivedAt":"2026-03-31T10:00:01+00:00","correlationId":"b2c3d4e5-f6a7-8901-bcde-f12345678901","notes":null}

